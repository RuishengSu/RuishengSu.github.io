{% capture footer_contents %}
  &copy; Copyright {{ site.time | date: '%Y' }}
  {{ site.first_name }}
  {{ site.middle_name }}
  {{ site.last_name }}. {{ site.footer_text }}
  {% if site.impressum_path %}
    <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
  {% endif %}
  {% if site.last_updated %}
    Last updated: {{ 'now' | date: '%B, %Y' }}.
  {% endif %}
  <span class="hits-counter" style="display: inline-flex; margin-left: 15px; vertical-align: middle; line-height: 1; height: 1em;">
    <img 
      src="https://hitscounter.dev/api/hit?url=https%3A%2F%2Fruishengsu.github.io&label=hits&icon=eye-fill&color=%23212529&message=&style=flat&tz=Europe%2FAmsterdam"
      style="height: 1em; max-height: 1em; width: auto; display: block; vertical-align: middle;"
    >
  </span>
  {% comment %}
  <span class="mapmyvisitors-widget" style="width: 15px; height: 15px; display: inline-flex; margin-left: 15px; align-items: center; height: 1em; vertical-align: middle;">
    <!-- mapmyvisitors embed code -->
    <script type="text/javascript" id="mmvst_globe" src="https://mapmyvisitors.com/globe.js?d=FDQZO8ncZuXbsyKvTPThVJ0LwF5I78YuMs-5LuVgmGY"></script>
  </span>
  <span class="clustrmaps-widget" style="width: 15px; height: 15px; display: inline-flex; margin-left: 15px; align-items: center; height: 1em; vertical-align: middle;">
    <!-- ClustrMaps embed code -->
    <script type="text/javascript" id="clstr_globe" src="https://clustrmaps.com/globe.js?d=42dMic-TpoWi5KT00j9lwOHKCPX2FcGNSLnYTLj3wik"></script>
  </span>
  {% endcomment %}
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}
